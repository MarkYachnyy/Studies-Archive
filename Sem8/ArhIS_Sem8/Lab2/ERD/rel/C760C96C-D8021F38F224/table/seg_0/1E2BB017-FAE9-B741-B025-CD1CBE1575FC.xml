<afterCreate><![CDATA[CREATE OR REPLACE TRIGGER TRG_AutoViolationDetect
AFTER INSERT ON SensorEvent
FOR EACH ROW
DECLARE
  v_planned TIMESTAMP;
  v_deviation_minutes NUMBER;
  v_train_id BIGINT;
BEGIN
  SELECT plannedDeparture, id INTO v_planned, v_train_id
  FROM TrainSchedule 
  WHERE ABS(EXTRACT(EPOCH FROM (:NEW.eventTime - plannedDeparture))) / 30 < 2 
  ORDER BY ABS(EXTRACT(EPOCH FROM (:NEW.eventTime - plannedDeparture))) 
  LIMIT 1;
  
  IF v_planned IS NOT NULL THEN
    v_deviation_minutes := EXTRACT(EPOCH FROM (:NEW.eventTime - v_planned)) / 30;
    
    IF ABS(v_deviation_minutes) > 0.5 THEN 
      INSERT INTO Violation (
        type, actualTime, plannedTime, sensorEventId, trainScheduleId
      ) VALUES (
        CASE 
          WHEN v_deviation_minutes < 0 THEN 'EARLY_DEPARTURE'
          ELSE 'LATE_DEPARTURE'
        END,
        :NEW.eventTime, v_planned, :NEW.id, v_train_id
      );
    END IF;
  END IF;
END;
]]></afterCreate>
